{
  "name": "winget-manifest-lint",
  "version": "0.0.0",
  "description": "Offline linter for winget package manifests",
  "type": "module",
  "license": "MIT",
  "author": "jeffwlawson",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "winget-manifest-lint": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run test",
    "corpus": "tsx scripts/lint-corpus.ts"
  },
  "dependencies": {
    "yaml": "2.8.1"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "0.12.0",
    "@standard-schema/spec": "^1.0.0",
    "@types/node": "24.10.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
